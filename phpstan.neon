parameters:
    level: 6
    parallel:
        maximumNumberOfProcesses: 1
    paths:
        - includes/
        - kratt.php
    bootstrapFiles:
        - vendor/autoload.php
        - phpstan-bootstrap.php
    excludePaths:
        - vendor/ (?)
        - node_modules/ (?)
        - build/ (?)
        - tests/ (?)
